#!/usr/bin/env bash
# Copy to secrets.local.sh (gitignored) and fill in your local API keys:
#   cp DevOps/env/secrets.local.sh.example DevOps/env/secrets.local.sh
#
# Runner scripts source secrets.local.sh automatically when present.
#
# Default vector store is PgVector (local Postgres) — no API keys required for ingest/search.
# Uncomment below only if you use OpenAI vector store or AWS/Bedrock features.

# export AWS_ACCESS_KEY_ID=your-key
# export AWS_SECRET_ACCESS_KEY=your-secret
# export BEDROCK_AGENT_ALIAS_ID=your-alias-id

# export VECTOR_DB_OPENAI_API_KEY=sk-...
# export OPENAI_API_KEY=sk-...   # fallback if VECTOR_DB_OPENAI_API_KEY unset
# export VECTOR_DB_OPENAI_ORG_ID=org-...
# export VECTOR_DB_OPENAI_VECTOR_STORE_ID=vs_...
