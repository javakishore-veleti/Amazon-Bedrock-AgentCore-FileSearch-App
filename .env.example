# Bootstrap selector for profile-based configuration.
# See middleware/amazon-bedrock-app/config/README.md for full documentation.
#
# APP_PROFILE=local      (default) — laptop dev, SQLite
# APP_PROFILE=docker       — local Docker stack, Postgres
# APP_PROFILE=production   — production stub (alias: prod)
#
# Secrets are NOT stored in files. Export them as environment variables, e.g.:
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
#   VECTOR_DB_OPENAI_API_KEY
#   VECTOR_DB_OPENAI_VECTOR_STORE_ID
#   DATABASE_URL or BOOK_INGEST_DB_URL

APP_PROFILE=local
