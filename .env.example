# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_AGENT_ALIAS_ID=your_agent_alias_id

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
PORT=3000
PYTHON_PORT=8000

# File Search Configuration
MAX_FILE_SIZE_MB=100
SUPPORTED_FILE_TYPES=.pdf,.txt,.json,.csv,.docx

# ============================================================
# Vector Store Configuration (VECTOR_DB_*)
# ============================================================
# Default vector store the app uses. One of:
#   openai | aws_opensearch | mongodb | chroma | pinecone | pgvector
VECTOR_DB_PROVIDER=openai

# --- Cloud provider auth (for cloud-hosted stores) ---
# AWS: prefer a named profile over static keys.
VECTOR_DB_AWS_PROFILE=Amazon-Bedrock-AgentCore-FileSearch-App
VECTOR_DB_AWS_REGION=us-east-1
# Azure: service principal (client credentials).
VECTOR_DB_AZURE_TENANT_ID=your_azure_tenant_id
VECTOR_DB_AZURE_CLIENT_ID=your_azure_client_id
VECTOR_DB_AZURE_CLIENT_SECRET=your_azure_client_secret
VECTOR_DB_AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
# GCP: service account.
VECTOR_DB_GCP_PROJECT_ID=your_gcp_project_id
VECTOR_DB_GCP_SERVICE_ACCOUNT_JSON=/path/to/gcp-service-account.json

# --- OpenAI Vector Store ---
VECTOR_DB_OPENAI_API_KEY=sk-your_openai_api_key
VECTOR_DB_OPENAI_ORG_ID=your_openai_org_id
VECTOR_DB_OPENAI_BASE_URL=https://api.openai.com/v1
# Server-generated id of your OpenAI vector store. Create it once (dashboard or
# API), then paste the vs_... id here.
VECTOR_DB_OPENAI_VECTOR_STORE_ID=vs_your_vector_store_id

# --- AWS OpenSearch (auth via AWS profile above) ---
VECTOR_DB_AWS_OPENSEARCH_PROFILE=Amazon-Bedrock-AgentCore-FileSearch-App
VECTOR_DB_AWS_OPENSEARCH_REGION=us-east-1
VECTOR_DB_AWS_OPENSEARCH_ENDPOINT=https://search-your-domain.us-east-1.es.amazonaws.com
VECTOR_DB_AWS_OPENSEARCH_INDEX=file-search
VECTOR_DB_AWS_OPENSEARCH_USE_SSL=true

# --- MongoDB Atlas Vector Search ---
VECTOR_DB_MONGODB_URI=mongodb+srv://cluster0.xxxxx.mongodb.net
VECTOR_DB_MONGODB_USERNAME=your_mongodb_username
VECTOR_DB_MONGODB_PASSWORD=your_mongodb_password
VECTOR_DB_MONGODB_DATABASE=file_search
VECTOR_DB_MONGODB_COLLECTION=embeddings
VECTOR_DB_MONGODB_INDEX=vector_index

# --- Chroma ---
VECTOR_DB_CHROMA_HOST=localhost
VECTOR_DB_CHROMA_PORT=8000
VECTOR_DB_CHROMA_AUTH_TOKEN=your_chroma_auth_token
VECTOR_DB_CHROMA_COLLECTION=file_search
VECTOR_DB_CHROMA_PERSIST_DIR=

# --- Pinecone ---
VECTOR_DB_PINECONE_API_KEY=your_pinecone_api_key
VECTOR_DB_PINECONE_ENVIRONMENT=us-east-1-aws
VECTOR_DB_PINECONE_INDEX=file-search
VECTOR_DB_PINECONE_HOST=

# --- PgVector (PostgreSQL) ---
VECTOR_DB_PGVECTOR_HOST=localhost
VECTOR_DB_PGVECTOR_PORT=5432
VECTOR_DB_PGVECTOR_DATABASE=file_search
VECTOR_DB_PGVECTOR_USER=postgres
VECTOR_DB_PGVECTOR_PASSWORD=your_pgvector_password
VECTOR_DB_PGVECTOR_SSLMODE=prefer
VECTOR_DB_PGVECTOR_TABLE=embeddings
